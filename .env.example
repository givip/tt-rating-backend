# Database
DATABASE_URL=postgresql://ttrge:ttrge@localhost:5432/ttrge

# Auth
# Strategy selector — 'password' (default) or 'phone-otp'.
AUTH_STRATEGY=password
# Access token (JWT) TTL. Format: Ns | Nm | Nh | Nd, or bare seconds.
AUTH_ACCESS_TTL=15m
# Refresh token TTL. Stored in DB, rotated on use.
AUTH_REFRESH_TTL=30d
# bcrypt cost for password hashing. Min 12 is enforced in code.
AUTH_BCRYPT_COST=12
# HMAC key for signing access tokens. REQUIRED in production (boot will fail otherwise).
JWT_SECRET=change-me-in-production

# SMS (Georgian carrier)
SMS_API_KEY=
SMS_SENDER_ID=TTRGE

# Google Cloud
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
CLOUD_RUN_JOB_NAME=ttrge-rating-worker
GOOGLE_CLOUD_REGION=europe-west3

# Sentry
SENTRY_DSN=

# App
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
